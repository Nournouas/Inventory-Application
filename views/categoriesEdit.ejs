<html>
  <%- include("partials/head", {title: title}) %>
  <body>
    <header>
      <%- include("partials/nav", {active: "categories"}) %>
    </header>
    <main class="products-edit-main">
      <h1>Edit Category</h1>
      <br>
      <form class="product-form" action="/categories/<%= category.id %>/edit" method="post">
        <label for="categoryName">Category Name:</label>
        <% console.log() %>
        <input type="text" name="categoryName" id="categoryName" value="<%= category.categoryname %>">
        <label for="categoryTotal">Total:</label>
        <input type="number" name="categoryTotal" id="categoryTotal" value="<%= category.total %>">
        <button type="submit">Edit Category</button>
      </form>
      <a class="go-back-button" href="/categories">Go Back</a>
    </main>

    <%- include("partials/footer") %>
  </body>
</html>